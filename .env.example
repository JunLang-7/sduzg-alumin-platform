# MySQL
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=sdu_alumni_db
MYSQL_USER=sdu_alumni
MYSQL_PASSWORD=change-me
MYSQL_HOST_PORT=3307

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# Redis
REDIS_PASSWORD=
REDIS_HOST_PORT=6379

# Rate limit
RATE_LIMIT_ENABLED=false
RATE_LIMIT_GLOBAL_RPM=120
RATE_LIMIT_AUTH_RPM=10
RATE_LIMIT_VERIFY_CODE_RPM=3
RATE_LIMIT_ADMIN_RPM=30

# CORS
CORS_ENABLED=false
CORS_ALLOWED_ORIGINS=

# Host ports
API_HOST_PORT=8080
WEB_HOST_PORT=80

# API proxy settings, comma-separated CIDR/IP list. Leave empty when serving directly.
SERVER_TRUSTED_PROXIES=

# SMS
SMS_ENABLED=false
SMS_API_KEY=
SMS_API_SECRET=
SMS_SIGN_NAME=your-sign-name
SMS_TEMPLATE_CODE=

# Email
EMAIL_ENABLED=false
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=your-name
