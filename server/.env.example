APP_NAME=sdu-alumni-platform
APP_ENV=development

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_SHUTDOWN_TIMEOUT=10s
SERVER_TRUSTED_PROXIES=

DB_ENABLED=false
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=sdu_alumni
DB_PASSWORD=sdu_alumni_password
DB_NAME=sdu_alumni_db
DB_PARAMS=charset=utf8mb4&parseTime=true&loc=Local
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h

REDIS_ENABLED=false
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s

AUTH_JWT_SECRET=dev-only-change-me
AUTH_ACCESS_TOKEN_TTL=24h

STORAGE_ENABLED=false
STORAGE_ENDPOINT=127.0.0.1:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin123
STORAGE_BUCKET=sdu-alumni-files
STORAGE_USE_SSL=false
STORAGE_PUBLIC_ENDPOINT=

SMS_ENABLED=false
SMS_TENCENT_SECRET_ID=
SMS_TENCENT_SECRET_KEY=
SMS_TENCENT_REGION=ap-beijing
SMS_TENCENT_APP_ID=
SMS_TENCENT_SIGN_NAME=山东大学政管学院
SMS_TENCENT_TEMPLATE_ID=
SMS_TENCENT_ENDPOINT=sms.tencentcloudapi.com

EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=山东大学政管学院

RATE_LIMIT_ENABLED=false
RATE_LIMIT_GLOBAL_RPM=120
RATE_LIMIT_AUTH_RPM=10
RATE_LIMIT_VERIFY_CODE_RPM=3
RATE_LIMIT_ADMIN_RPM=30

CORS_ENABLED=false
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173
